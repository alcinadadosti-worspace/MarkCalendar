rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /calendarData/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
    match /authSetupDone/{docId} {
      allow read, write: if true;
    }
    match /pinMap/{docId} {
      allow read, write: if true;
    }
  }
}
